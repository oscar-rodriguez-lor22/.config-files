# keybinings
set $mod Mod4

## Switching through workspaces
bindsym $mod+Tab workspace next
bindsym $mod+1 workspace number 1: WS1
bindsym $mod+2 workspace number 2: WS2
bindsym $mod+3 workspace number 3: WS3
bindsym $mod+4 workspace number 4: WS4
bindsym $mod+5 workspace number 5: WS5
bindsym $mod+6 workspace number 6: WS6
bindsym $mod+7 workspace number 7: WS7
bindsym $mod+8 workspace number 8: WS8
bindsym $mod+9 workspace number 9: WS9
bindsym $mod+0 workspace number 10: WS10
bindsym $mod+n exec --no-startup-id ~/.config/i3/scripts/empty_workspace

## Run apps
bindsym $mod+Return exec --no-startup-id kitty
bindsym $mod+s exec --no-startup-id /usr/bin/thunar

## Logout/Lock screen
bindsym $mod+e exec --no-startup-id ~/.config/i3/scripts/power-menu
bindsym $mod+l exec --no-startup-id ~/.config/i3/scripts/blur-lock

## Tiling/window behavior
bindsym $mod+f fullscreen toggle
bindsym $mod+v split v
bindsym $mod+h split h
bindsym $mod+q kill

## Reload configs
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

## Rofi
bindsym $mod+r exec --no-startup-id rofi -show drun 

## Brightness
bindsym $mod+F1 exec --no-startup-id ~/.config/i3/scripts/brightness-control down
bindsym $mod+F2 exec --no-startup-id ~/.config/i3/scripts/brightness-control up

## Volume
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/i3/scripts/volume_brightness.sh volume_up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/i3/scripts/volume_brightness.sh volume_down

## Screenshot
bindsym Print exec "flameshot gui"

## Clipboard
bindsym $mod+c exec --no-startup-id CM_LAUNCHER=rofi clipmenu

## Brightness
# Sudo-less brightness control
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-
