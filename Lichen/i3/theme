# Theme
font pango: JetBrains Mono 10

# Tiling
workspace_layout default
new_window pixel 1
gaps inner 4
gaps outer 2

# Background
exec --no-startup-id sleep 1 && feh --bg-fill ~/Pictures/bg/totoro-sunflowers.png

# Variables (for windows & bar)
set $foreground 		#ffebc3
set $background 		#3c4c55
set $color0			#7f8f9f
set $color1			#fd8489
set $color2			#a9dd9d
set $color3			#f0aa8a
set $color4			#bdd0e5
set $color5			#daccf0
set $color6			#a9dd9d
set $color7			#ffebc3
set $color8			#7f8f9f
set $color9			#fd8489
set $color10			#a9dd9d
set $color11			#eed094
set $color12			#bdd0e5
set $color13			#daccf0
set $color14			#a9dd9d
set $color15			#ffebc3

# Windows
## class			border		background		text		indicator		child_border	
client.focused			$color8		$color7		$foreground			
client.unfocused		$color4		$background 	       	$foreground
client.focused_inactive		$color4		$background			$foreground
client.urgent			$color8		$color1			$forground

# Bar
bar {
	colors{
		## bar
		background $background
		statusline $color7
		## workspaces (<border> <background> <text>)
		focused_workspace	$foreground	$color8		$foreground
		inactive_workspace	$background	$color8		$foreground
	}

	font pango: Font Awesome 6 Free, Font Awesome 6 Brands, JetBrains Mono 4
	status_command i3blocks -c ~/.config/i3/i3blocks.conf
	position top
	tray_padding 1
	workspace_buttons yes 
	strip_workspace_numbers yes
	i3bar_command i3bar --transparency
}
