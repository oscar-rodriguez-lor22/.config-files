# Imports
include themes/ansi.conf

# Font
font_family JetBrainsMono Nerd Font
font_size 12.0

# Styles
cursor_shape block
cursor_beam_width 2
background_opacity 0.90
blur_radius 5.0
enable_audio_bell no
hide_cursor_when_typing yes


# BEGIN_KITTY_THEME
# Constant Perceptual Luminosity (dark)
include current-theme.conf
# END_KITTY_THEME